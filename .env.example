# Copy this file to .env and fill in your values

# Google Sheet ID (from the sheet URL)
SHEET_ID=your-google-sheet-id-here

# Path to your Google service account credentials file
# (Leave blank to use the default credentials.json in the same folder)
# GOOGLE_CREDENTIALS=credentials.json

# Slack incoming webhook URL for run completion notifications
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# How many companies to fetch at once (higher = faster, but more load on Greenhouse's API)
CONCURRENCY=20
